generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurants         Restaurant[]
  subscription        Subscription?
  passwordResetTokens PasswordResetToken[]
}

model Subscription {
  id String @id @default(cuid())

  plan   String @default("FREE") // FREE, PRO
  status String @default("ACTIVE") // ACTIVE, TRIAL, CANCELLED, PAST_DUE

  trialEndsAt DateTime?

  proTrialEndsAt        DateTime?
  websiteTrialEndsAt    DateTime?
  qrOrderingTrialEndsAt DateTime?

  restaurantLimit Int @default(1)
  priceMonthly    Int @default(0)

  websiteAddon    Boolean @default(false)
  qrOrderingAddon Boolean @default(false)

  stripeCustomerId                String?
  stripeProSubscriptionId         String?
  stripeWebsiteSubscriptionId     String?
  stripeQrOrderingSubscriptionId  String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  email   String?
  phone   String?
  address String?

  // Mini-site — estado/base
  websiteEnabled      Boolean @default(false)
  websiteTemplate     String  @default("PREMIUM")
  websitePrimaryColor String? @default("#111827")

  // Mini-site — hero
  websiteHeadline    String?
  websiteDescription String?
  websiteCuisine     String?
  websiteInstagram   String?
  websiteHeroImage   String?
  websiteLogoImage   String?

  // Mini-site — storytelling
  websiteAboutTitle   String?
  websiteAboutText    String?
  websiteFeatureTitle String?
  websiteFeatureText  String?

  // Mini-site — textos editáveis
  websiteSectionTitle        String?
  websiteSectionText         String?
  websiteGalleryTitle        String?
  websiteGalleryDescription  String?
  websiteLocationTitle       String?
  websiteLocationDescription String?
  websiteFinalCtaTitle       String?
  websiteFinalCtaText        String?

  // Mini-site — galeria
  websiteGalleryImage1 String?
  websiteGalleryImage2 String?
  websiteGalleryImage3 String?
  websiteGalleryImage4 String?

  websiteGalleryTitle1 String?
  websiteGalleryTitle2 String?
  websiteGalleryTitle3 String?
  websiteGalleryTitle4 String?

  // Mini-site — menu
  websiteMenuTitle       String?
  websiteMenuDescription String?
  websiteMenuPdf         String?
  websiteMenus           WebsiteMenu[]

  // Mini-site — SEO/domínio
  websiteSeoTitle       String?
  websiteSeoDescription String?
  customDomain          String?
  customDomainVerified  Boolean @default(false)

  plan String @default("FREE")

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  reservationMode           String  @default("TABLES")
  totalCapacity             Int?
  manualApprovalGuests      Int?
  approvalOnTableMerge      Boolean @default(true)
  onlineReservationsEnabled Boolean @default(true)

  mondayOpen   Boolean @default(false)
  mondayLunch  String?
  mondayDinner String?

  tuesdayOpen   Boolean @default(false)
  tuesdayLunch  String?
  tuesdayDinner String?

  wednesdayOpen   Boolean @default(false)
  wednesdayLunch  String?
  wednesdayDinner String?

  thursdayOpen   Boolean @default(false)
  thursdayLunch  String?
  thursdayDinner String?

  fridayOpen   Boolean @default(false)
  fridayLunch  String?
  fridayDinner String?

  saturdayOpen   Boolean @default(false)
  saturdayLunch  String?
  saturdayDinner String?

  sundayOpen   Boolean @default(false)
  sundayLunch  String?
  sundayDinner String?

  tables       Table[]
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderingCategories OrderingCategory[]
  orderingOrders     OrderingOrder[]

  orderingTableSessions OrderingTableSession[]

  qrOrderingEnabled  Boolean @default(true)
  qrAllowWaiterCall  Boolean @default(true)
  qrAllowBillRequest Boolean @default(true)
  qrWelcomeMessage   String?
}

model WebsiteMenu {
  id    String @id @default(cuid())
  title String
  pdf   String

  sortOrder Int @default(0)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id       String @id @default(cuid())
  number   Int
  capacity Int

  x     Int    @default(80)
  y     Int    @default(80)
  shape String @default("square")

  mergeGroupId String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  reservations Reservation[]

  createdAt DateTime @default(now())
}

model Customer {
  id String @id @default(cuid())

  name  String
  phone String  @unique
  email String?

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reservation {
  id String @id @default(cuid())

  customerName String
  phone        String
  email        String?
  date         DateTime
  guests       Int

  status String @default("CONFIRMED")

  source      String  @default("MANUAL")
  cancelledBy String?

  // CONFIRMED
  // PENDING
  // SEATED
  // FINISHED
  // NO_SHOW
  // CANCELLED
  // REJECTED

  approvalReason String?

  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model OrderingCategory {
  id           String @id @default(cuid())
  restaurantId String

  name     String
  position Int    @default(0)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  products OrderingProduct[]
}

model OrderingProduct {
  id         String @id @default(cuid())
  categoryId String

  name        String
  description String?

  price Decimal @db.Decimal(10, 2)

  vatRate   Int     @default(23)
  sku       String?
  sortOrder Int     @default(0)

  imageUrl  String?
  allergens String?
  featured  Boolean @default(false)

  active Boolean @default(true)

  category OrderingCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model OrderingOrder {
  id           String @id @default(cuid())
  restaurantId String

  tableNumber Int

  status String @default("PENDING")

  subtotal Decimal @default(0) @db.Decimal(10, 2)
  vatTotal Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @default(0) @db.Decimal(10, 2)

  notes String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  items OrderingOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String?
  session   OrderingTableSession? @relation(fields: [sessionId], references: [id])
}

model OrderingOrderItem {
  id      String @id @default(cuid())
  orderId String

  productId String?

  productName String
  quantity    Int

  unitPrice Decimal @db.Decimal(10, 2)
  vatRate   Int     @default(23)

  lineSubtotal Decimal @default(0) @db.Decimal(10, 2)
  lineVat      Decimal @default(0) @db.Decimal(10, 2)
  lineTotal    Decimal @default(0) @db.Decimal(10, 2)

  order OrderingOrder @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}

model OrderingTableSession {
  id           String @id @default(cuid())
  restaurantId String
  tableNumber  Int

  status String @default("OPEN")

  openedAt DateTime  @default(now())
  closedAt DateTime?

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  orders     OrderingOrder[]

  requestedBillAt   DateTime?
  requestedWaiterAt DateTime?
}

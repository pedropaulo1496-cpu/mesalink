generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurants         Restaurant[]
  subscription        Subscription?
  passwordResetTokens PasswordResetToken[]
}

model Subscription {
  id String @id @default(cuid())

  plan   String @default("FREE") // FREE, PRO
  status String @default("TRIAL") // TRIAL, ACTIVE, CANCELLED, PAST_DUE

  trialEndsAt DateTime?

  restaurantLimit Int @default(1)
  priceMonthly    Int @default(0)

  websiteAddon Boolean @default(false)

  stripeCustomerId            String?
  stripeProSubscriptionId     String?
  stripeWebsiteSubscriptionId String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  email   String?
  phone   String?
  address String?

  // Mini-site — estado/base
  websiteEnabled      Boolean @default(false)
  websiteTemplate     String  @default("PREMIUM")
  websitePrimaryColor String? @default("#111827")

  // Mini-site — hero
  websiteHeadline    String?
  websiteDescription String?
  websiteCuisine     String?
  websiteInstagram   String?
  websiteHeroImage   String?
  websiteLogoImage   String?

  // Mini-site — storytelling
  websiteAboutTitle   String?
  websiteAboutText    String?
  websiteFeatureTitle String?
  websiteFeatureText  String?

  // Mini-site — textos editáveis
  websiteSectionTitle        String?
  websiteSectionText         String?
  websiteGalleryTitle        String?
  websiteGalleryDescription  String?
  websiteLocationTitle       String?
  websiteLocationDescription String?
  websiteFinalCtaTitle       String?
  websiteFinalCtaText        String?

  // Mini-site — galeria
  websiteGalleryImage1 String?
  websiteGalleryImage2 String?
  websiteGalleryImage3 String?
  websiteGalleryImage4 String?

  websiteGalleryTitle1 String?
  websiteGalleryTitle2 String?
  websiteGalleryTitle3 String?
  websiteGalleryTitle4 String?

  // Mini-site — menu
  websiteMenuTitle       String?
  websiteMenuDescription String?
  websiteMenuPdf         String?
  websiteMenus           WebsiteMenu[]

  // Mini-site — SEO/domínio
  websiteSeoTitle       String?
  websiteSeoDescription String?
  customDomain          String?
  customDomainVerified  Boolean @default(false)

  plan String @default("FREE")

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  reservationMode           String  @default("TABLES")
  totalCapacity             Int?
  manualApprovalGuests      Int?
  approvalOnTableMerge      Boolean @default(true)
  onlineReservationsEnabled Boolean @default(true)

  mondayOpen   Boolean @default(false)
  mondayLunch  String?
  mondayDinner String?

  tuesdayOpen   Boolean @default(false)
  tuesdayLunch  String?
  tuesdayDinner String?

  wednesdayOpen   Boolean @default(false)
  wednesdayLunch  String?
  wednesdayDinner String?

  thursdayOpen   Boolean @default(false)
  thursdayLunch  String?
  thursdayDinner String?

  fridayOpen   Boolean @default(false)
  fridayLunch  String?
  fridayDinner String?

  saturdayOpen   Boolean @default(false)
  saturdayLunch  String?
  saturdayDinner String?

  sundayOpen   Boolean @default(false)
  sundayLunch  String?
  sundayDinner String?

  tables       Table[]
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebsiteMenu {
  id    String @id @default(cuid())
  title String
  pdf   String

  sortOrder Int @default(0)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id       String @id @default(cuid())
  number   Int
  capacity Int

  x     Int    @default(80)
  y     Int    @default(80)
  shape String @default("square")

  mergeGroupId String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  reservations Reservation[]

  createdAt DateTime @default(now())
}

model Customer {
  id String @id @default(cuid())

  name  String
  phone String  @unique
  email String?

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reservation {
  id String @id @default(cuid())

  customerName String
  phone        String
  email        String?
  date         DateTime
  guests       Int

  status String @default("CONFIRMED")

  source      String  @default("MANUAL")
  cancelledBy String?

  // CONFIRMED
  // PENDING
  // SEATED
  // FINISHED
  // NO_SHOW
  // CANCELLED
  // REJECTED

  approvalReason String?

  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

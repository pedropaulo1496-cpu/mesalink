generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurants         Restaurant[]
  subscription        Subscription?
  passwordResetTokens PasswordResetToken[]
  printBridgeDevices  PrintBridgeDevice[]
}

model Subscription {
  id String @id @default(cuid())

  plan   String @default("ESSENTIALS") // TRIAL, ESSENTIALS, GROWTH
  status String @default("TRIAL") // TRIAL, ACTIVE, CANCELED, PAST_DUE

  trialEndsAt DateTime?

  restaurantLimit Int @default(1)
  priceMonthly    Int @default(0)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  email   String?
  phone   String?
  address String?

  // Mini-site — estado/base
  websiteEnabled      Boolean @default(false)
  websiteTemplate     String  @default("PREMIUM")
  websitePrimaryColor String? @default("#111827")

  // Mini-site — hero
  websiteHeadline    String?
  websiteDescription String?
  websiteCuisine     String?
  websiteInstagram   String?
  websiteHeroImage   String?
  websiteLogoImage   String?

  // Mini-site — storytelling
  websiteAboutTitle   String?
  websiteAboutText    String?
  websiteFeatureTitle String?
  websiteFeatureText  String?

  // Mini-site — textos editáveis
  websiteSectionTitle        String?
  websiteSectionText         String?
  websiteGalleryTitle        String?
  websiteGalleryDescription  String?
  websiteLocationTitle       String?
  websiteLocationDescription String?
  websiteFinalCtaTitle       String?
  websiteFinalCtaText        String?

  // Mini-site — galeria
  websiteGalleryImage1 String?
  websiteGalleryImage2 String?
  websiteGalleryImage3 String?
  websiteGalleryImage4 String?

  websiteGalleryTitle1 String?
  websiteGalleryTitle2 String?
  websiteGalleryTitle3 String?
  websiteGalleryTitle4 String?

  // Mini-site — menu
  websiteMenuTitle       String?
  websiteMenuDescription String?
  websiteMenuPdf         String?
  websiteMenus           WebsiteMenu[]

  // Mini-site — SEO/domínio
  websiteSeoTitle       String?
  websiteSeoDescription String?
  customDomain          String?
  customDomainVerified  Boolean @default(false)

  plan String @default("FREE")

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  reservationMode           String  @default("TABLES")
  totalCapacity             Int?
  manualApprovalGuests      Int?
  approvalOnTableMerge      Boolean @default(true)
  onlineReservationsEnabled Boolean @default(true)

  mondayOpen   Boolean @default(false)
  mondayLunch  String?
  mondayDinner String?

  tuesdayOpen   Boolean @default(false)
  tuesdayLunch  String?
  tuesdayDinner String?

  wednesdayOpen   Boolean @default(false)
  wednesdayLunch  String?
  wednesdayDinner String?

  thursdayOpen   Boolean @default(false)
  thursdayLunch  String?
  thursdayDinner String?

  fridayOpen   Boolean @default(false)
  fridayLunch  String?
  fridayDinner String?

  saturdayOpen   Boolean @default(false)
  saturdayLunch  String?
  saturdayDinner String?

  sundayOpen   Boolean @default(false)
  sundayLunch  String?
  sundayDinner String?

  tables       Table[]
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderingCategories OrderingCategory[]
  orderingOrders     OrderingOrder[]

  orderingTableSessions OrderingTableSession[]

  qrOrderingEnabled       Boolean           @default(true)
  qrAllowWaiterCall       Boolean           @default(true)
  qrAllowBillRequest      Boolean           @default(true)
  qrWelcomeMessage        String?
  floorRooms              FloorRoom[]
  marketingActions        MarketingAction[]
  googleReviewUrl         String?
  reviewRedirectThreshold Int               @default(4)
  averageTicket           Float?            @default(25)
  birthdayOffer           String?
  recoveryOffer           String?
  vipOffer                String?
  bronzeVipOffer          String?
  silverVipOffer          String?
  goldVipOffer            String?
  platinumVipOffer        String?
  posEnabled              Boolean           @default(false)

  posOrders   POSOrder[]
  posPayments POSPayment[]

  posTableSessions POSTableSession[]

  fiscalIntegration        FiscalIntegration?
  fiscalDocuments          FiscalDocument[]
  posCashRegisters         POSCashRegister[]
  posDiscounts             POSDiscount[]
  posReceipts              POSReceipt[]
  posTableTransfers        POSTableTransfer[]
  posDiscountCodes         POSDiscountCode[]
  posCashMovements         POSCashMovement[]
  productProductionCenters ProductionCenter[]
  printJobs                PrintJob[]
  printers                 RestaurantPrinter[]
  printBridgeToken         String?                 @unique
  printBridgeRestaurants   PrintBridgeRestaurant[]
  customers                Customer[]
}

model WebsiteMenu {
  id    String @id @default(cuid())
  title String
  pdf   String

  sortOrder Int @default(0)

  roomId String?
  room   FloorRoom? @relation(fields: [roomId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  restaurantId String?
}

model FloorRoom {
  id String @id @default(cuid())

  name      String
  sortOrder Int    @default(0)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  tables Table[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  websiteMenus WebsiteMenu[]
}

model Table {
  id       String @id @default(cuid())
  number   Int
  capacity Int

  x     Int    @default(80)
  y     Int    @default(80)
  shape String @default("square")

  mergeGroupId String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  roomId       String?
  room         FloorRoom? @relation(fields: [roomId], references: [id])

  reservations Reservation[]

  createdAt        DateTime          @default(now())
  posTableSessions POSTableSession[]
}

model Customer {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name  String
  phone String
  email String?

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketingOptIn    Boolean   @default(false)
  marketingJoinedAt DateTime?

  birthDate DateTime?

  lastVisitAt       DateTime?
  lastReservationAt DateTime?

  visitCount  Int @default(0)
  totalVisits Int @default(0)

  vipTier   String?
  riskScore Int     @default(0)

  notes String?
  tags  String[] @default([])

  source String? // RESERVATION, MANUAL, IMPORT

  marketingActions MarketingAction[]
  posTableSessions POSTableSession[]

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@index([email])
  @@index([phone])
}

model Reservation {
  id String @id @default(cuid())

  customerName String
  phone        String
  email        String?
  date         DateTime
  guests       Int

  status String @default("CONFIRMED")

  source      String  @default("MANUAL")
  cancelledBy String?

  notes String?

  approvalReason String?

  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt        DateTime          @default(now())
  posTableSessions POSTableSession[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model OrderingCategory {
  id           String @id @default(cuid())
  restaurantId String

  name     String
  position Int    @default(0)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  products    OrderingProduct[]
  activeInPOS Boolean           @default(true)
}

model OrderingProduct {
  id         String @id @default(cuid())
  categoryId String

  name        String
  description String?

  price Decimal @db.Decimal(10, 2)

  vatRate   Int     @default(23)
  sku       String?
  sortOrder Int     @default(0)

  imageUrl  String?
  allergens String?
  featured  Boolean @default(false)

  active Boolean @default(true)

  category OrderingCategory @relation(fields: [categoryId], references: [id])

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  activeInPOS      Boolean        @default(true)
  activeInOrdering Boolean        @default(true)
  activeOnWebsite  Boolean        @default(true)
  posorderItems    POSOrderItem[]

  printName                String?
  productProductionCenters ProductProductionCenter[]
}

model OrderingOrder {
  id           String @id @default(cuid())
  restaurantId String

  tableNumber Int
  tableId     String?

  status String @default("PENDING")
  // PENDING
  // ACCEPTED
  // REJECTED

  subtotal Decimal @default(0) @db.Decimal(10, 2)
  vatTotal Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @default(0) @db.Decimal(10, 2)

  notes String?

  posOrderId String?
  acceptedAt DateTime?
  rejectedAt DateTime?
  printedAt  DateTime?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  items OrderingOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String?
  session   OrderingTableSession? @relation(fields: [sessionId], references: [id])
}

model OrderingOrderItem {
  id      String @id @default(cuid())
  orderId String

  productId String?

  productName String
  quantity    Int

  unitPrice Decimal @db.Decimal(10, 2)
  vatRate   Int     @default(23)

  lineSubtotal Decimal @default(0) @db.Decimal(10, 2)
  lineVat      Decimal @default(0) @db.Decimal(10, 2)
  lineTotal    Decimal @default(0) @db.Decimal(10, 2)

  order OrderingOrder @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}

model OrderingTableSession {
  id           String @id @default(cuid())
  restaurantId String
  tableNumber  Int

  status String @default("OPEN")

  openedAt DateTime  @default(now())
  closedAt DateTime?

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  orders     OrderingOrder[]

  requestedBillAt   DateTime?
  requestedWaiterAt DateTime?
}

model MarketingAutomation {
  id           String @id @default(cuid())
  restaurantId String

  type    String
  name    String
  enabled Boolean @default(true)

  triggerDays     Int?
  ratingThreshold Int?

  subject   String?
  message   String?
  offerType String?
  offerText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReviewFeedback {
  id            String  @id @default(cuid())
  restaurantId  String
  customerId    String?
  reservationId String?

  rating             Int
  comment            String?
  redirectedToGoogle Boolean @default(false)

  createdAt DateTime @default(now())
}

model MarketingAction {
  id String @id @default(cuid())

  restaurantId String
  customerId   String?
  automationId String?

  type   String
  status String @default("SENT")

  sentAt      DateTime  @default(now())
  openedAt    DateTime?
  clickedAt   DateTime?
  bookedAt    DateTime?
  convertedAt DateTime?

  reservationId String?

  estimatedRevenue Decimal? @db.Decimal(10, 2)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  customer Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
}

model POSTableSession {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  status String @default("OPEN")

  totalAmount Decimal @default(0) @db.Decimal(10, 2)

  openedAt DateTime  @default(now())
  closedAt DateTime?

  orders     POSOrder[]
  guestCount Int        @default(1)

  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)

  customerNif  String?
  customerName String?

  openedBy String?
  closedBy String?

  consultationCount Int @default(0)

  payments        POSPayment[]
  discounts       POSDiscount[]
  receipts        POSReceipt[]
  paidAmount      Decimal          @default(0)
  remainingAmount Decimal          @default(0)
  invoiceStatus   String           @default("NONE")
  invoiceId       String?
  invoiceNumber   String?
  invoiceUrl      String?
  invoiceIssuedAt DateTime?
  fiscalDocuments FiscalDocument[]
}

model POSOrder {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  tableSessionId String?
  tableSession   POSTableSession? @relation(fields: [tableSessionId], references: [id])

  source String @default("POS")

  status String @default("OPEN")

  subtotal Decimal @default(0) @db.Decimal(10, 2)

  items POSOrderItem[]

  createdAt   DateTime @default(now())
  orderNumber Int?

  discountAmount Decimal @default(0) @db.Decimal(10, 2)

  kitchenNotes  String?
  customerNotes String?

  updatedAt DateTime   @default(now()) @updatedAt
  printJobs PrintJob[]
}

model POSOrderItem {
  id String @id @default(cuid())

  orderId String
  order   POSOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   OrderingProduct? @relation(fields: [productId], references: [id])

  productName String

  quantity Int

  unitPrice Decimal @db.Decimal(10, 2)

  totalPrice Decimal @db.Decimal(10, 2)
  vatRate    Decimal @default(23) @db.Decimal(5, 2)

  paidQuantity   Int @default(0)
  voidedQuantity Int @default(0)

  notes String?

  createdAt      DateTime @default(now())
  discountType   String?
  discountValue  Decimal? @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)

  kitchenNotes String?
}

model POSPayment {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  tableSessionId String?
  tableSession   POSTableSession? @relation(fields: [tableSessionId], references: [id])

  cashRegisterId String?
  cashRegister   POSCashRegister? @relation(fields: [cashRegisterId], references: [id])

  amount Decimal @db.Decimal(10, 2)

  method String
  status String @default("PAID")

  receivedAmount Decimal? @db.Decimal(10, 2)
  changeAmount   Decimal? @db.Decimal(10, 2)

  reference String?

  createdAt      DateTime        @default(now())
  fiscalDocument FiscalDocument?
}

model FiscalIntegration {
  id String @id @default(cuid())

  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  provider String @default("MOLONI")

  clientId     String?
  clientSecret String? @db.Text

  companyId String?

  invoiceSerieId           String?
  simplifiedInvoiceSerieId String?
  creditNoteSerieId        String?

  accessToken    String?   @db.Text
  refreshToken   String?   @db.Text
  tokenExpiresAt DateTime?

  oauthState String?

  active Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FiscalDocument {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  paymentId String?     @unique
  payment   POSPayment? @relation(fields: [paymentId], references: [id])

  tableSessionId String?
  tableSession   POSTableSession? @relation(fields: [tableSessionId], references: [id])

  documentType String
  // INVOICE
  // SIMPLIFIED_INVOICE
  // RECEIPT
  // CREDIT_NOTE

  status String @default("DRAFT")
  // DRAFT
  // ISSUED
  // CANCELLED

  provider String @default("MOLONI")

  externalId     String?
  documentNumber String?

  totalAmount Decimal @db.Decimal(10, 2)

  pdfUrl String?

  relatedDocumentId String?
  relatedDocument   FiscalDocument?  @relation("FiscalCreditNoteRelation", fields: [relatedDocumentId], references: [id])
  creditNotes       FiscalDocument[] @relation("FiscalCreditNoteRelation")

  issuedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([restaurantId])
  @@index([paymentId])
  @@index([tableSessionId])
  @@index([documentType])
  @@index([status])
}

model POSCashRegister {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  status String @default("OPEN")

  openingAmount Decimal  @default(0) @db.Decimal(10, 2)
  closingAmount Decimal? @db.Decimal(10, 2)

  expectedCash Decimal? @db.Decimal(10, 2)
  difference   Decimal? @db.Decimal(10, 2)

  openedAt DateTime  @default(now())
  closedAt DateTime?

  payments  POSPayment[]
  movements POSCashMovement[]
}

model POSDiscount {
  id String @id @default(cuid())

  tableSessionId String?
  orderItemId    String?

  type String // AMOUNT | PERCENTAGE

  value Decimal @db.Decimal(10, 2)

  amount Decimal @db.Decimal(10, 2)

  reason String?

  createdAt         DateTime         @default(now())
  discountCodeId    String?
  discountCode      POSDiscountCode? @relation(fields: [discountCodeId], references: [id])
  restaurant        Restaurant?      @relation(fields: [restaurantId], references: [id])
  restaurantId      String?
  postableSession   POSTableSession? @relation(fields: [pOSTableSessionId], references: [id])
  pOSTableSessionId String?
}

model POSReceipt {
  id String @id @default(cuid())

  tableSessionId String

  type String
  // CONSULTATION
  // FINAL
  // INVOICE

  subtotal Decimal @db.Decimal(10, 2)

  discountAmount Decimal @default(0) @db.Decimal(10, 2)

  total Decimal @db.Decimal(10, 2)

  printedAt         DateTime         @default(now())
  restaurant        Restaurant?      @relation(fields: [restaurantId], references: [id])
  restaurantId      String?
  postableSession   POSTableSession? @relation(fields: [pOSTableSessionId], references: [id])
  pOSTableSessionId String?
}

model POSTableTransfer {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  fromTableId String?
  toTableId   String?

  fromSessionId String?
  toSessionId   String?

  reason String?

  createdAt DateTime @default(now())

  @@index([restaurantId])
  @@index([fromSessionId])
  @@index([toSessionId])
}

model POSDiscountCode {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  code String

  type  String // AMOUNT | PERCENTAGE
  value Decimal @db.Decimal(10, 2)

  active Boolean @default(true)

  startsAt DateTime?
  endsAt   DateTime?

  maxUses   Int?
  usedCount Int  @default(0)

  minimumSpend Decimal? @db.Decimal(10, 2)

  campaignId String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  discounts POSDiscount[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([code])
}

model POSCashMovement {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  cashRegisterId String
  cashRegister   POSCashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)

  type String
  // IN
  // OUT

  amount Decimal @db.Decimal(10, 2)

  reason String?

  createdAt DateTime @default(now())

  @@index([restaurantId])
  @@index([cashRegisterId])
  @@index([type])
}

model ProductionCenter {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name String

  active Boolean @default(true)

  position Int @default(0)

  productLinks ProductProductionCenter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  printJobs PrintJob[]
  printerId String?
  printer   RestaurantPrinter? @relation(fields: [printerId], references: [id])
}

model PrintJob {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  posOrderId String?
  posOrder   POSOrder? @relation(fields: [posOrderId], references: [id], onDelete: Cascade)

  productionCenterId String?           @map("productionCenterId")
  productionCenter   ProductionCenter? @relation(fields: [productionCenterId], references: [id])

  productProductionCenters ProductProductionCenter[]

  status String @default("PENDING")
  // PENDING
  // PRINTED
  // FAILED

  type String @default("PRODUCTION")
  // PRODUCTION
  // CONSULTATION
  // INVOICE

  title   String
  payload Json

  printedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  printerId String?
  printer   RestaurantPrinter? @relation(fields: [printerId], references: [id])

  @@index([restaurantId])
  @@index([posOrderId])
  @@index([productionCenterId])
  @@index([status])
}

model ProductProductionCenter {
  id String @id @default(cuid())

  productId String
  product   OrderingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  productionCenterId String
  productionCenter   ProductionCenter @relation(fields: [productionCenterId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  printJob   PrintJob? @relation(fields: [printJobId], references: [id])
  printJobId String?

  @@unique([productId, productionCenterId])
  @@index([productId])
  @@index([productionCenterId])
}

model RestaurantPrinter {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name String

  type String @default("KITCHEN")
  // KITCHEN
  // BAR
  // ROOM
  // CASHIER
  // OTHER

  method String @default("BROWSER")
  // BROWSER
  // BRIDGE
  // NETWORK

  ipAddress String?
  port      Int?

  active Boolean @default(true)

  productionCenters ProductionCenter[]

  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  printJobs      PrintJob[]
  bridgeMappings PrintBridgePrinterMapping[]

  @@index([restaurantId])
  @@index([active])
}

model PrintBridgeDevice {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  token String @unique

  active Boolean @default(true)

  lastSeenAt DateTime?

  restaurants PrintBridgeRestaurant[]
  mappings    PrintBridgePrinterMapping[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  windowsPrinters Json?

  @@index([userId])
  @@index([token])
}

model PrintBridgeRestaurant {
  id String @id @default(cuid())

  bridgeDeviceId String
  bridgeDevice   PrintBridgeDevice @relation(fields: [bridgeDeviceId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  active Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([bridgeDeviceId, restaurantId])
  @@index([restaurantId])
}

model PrintBridgePrinterMapping {
  id String @id @default(cuid())

  bridgeDeviceId String
  bridgeDevice   PrintBridgeDevice @relation(fields: [bridgeDeviceId], references: [id], onDelete: Cascade)

  restaurantPrinterId String
  restaurantPrinter   RestaurantPrinter @relation(fields: [restaurantPrinterId], references: [id], onDelete: Cascade)

  windowsPrinterName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bridgeDeviceId, restaurantPrinterId])
  @@index([restaurantPrinterId])
}
